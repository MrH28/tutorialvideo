2.4 VISUALIZAR ESPECTROS
# README: PLOT ESPECTROS VIS-NIR-MIR
# =================================
# Identifica picos de absorção minerais

def plot_espectros(df, cols_espectro, titulo='VIS-NIR'):
    plt.figure(figsize=(15,6))
    
    # Média espectral
    espectros_medio = df[cols_espectro].mean()
    
    plt.plot(espectros_medio.index.astype(float), espectros_medio.values, 
             linewidth=2, color='red')
    plt.fill_between(espectros_medio.index.astype(float), 
                     espectros_medio.values, alpha=0.3, color='orange')
    
    plt.title(f'{titulo} - Média Espectral', fontsize=14, fontweight='bold')
    plt.xlabel('Comprimento de Onda (nm)')
    plt.ylabel('Reflectância')
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig(f'{titulo.lower()}_media.png', dpi=300)
    plt.show()

# BANDAS NIR (ajuste nomes das colunas)
cols_nir = [col for col in df_nir.columns if col.isdigit() and 400 <= int(col) <= 2500]
plot_espectros(df_nir, cols_nir, 'VIS-NIR-SWIR')

# BANDAS MIR  
cols_mir = [col for col in df_mir.columns if col.isdigit() and 2500 <= int(col) <= 16000]
plot_espectros(df_mir, cols_mir, 'MIR')


2.5 PRÉ-PROCESSAMENTO ESPECTRAL
# README: FILTROS + DERIVADAS
# ===========================

from scipy.signal import savgol_filter

def preprocess_espectral(X, wl):
    """
    1. Filtro Savitzky-Golay
    2. 1ª e 2ª derivadas  
    3. Remover ruído
    """
    # StandardScaler
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)
    
    # 1ª Derivada (SG filter)
    fd = savgol_filter(X_scaled, window_length=11, polyorder=2, deriv=1)
    
    # 2ª Derivada
    sd = savgol_filter(X_scaled, window_length=11, polyorder=2, deriv=2)
    
    return {
        'raw': X_scaled,
        'fd': fd,
        'sd': sd
    }

# APLICAR
espectros_proc = preprocess_espectral(df_nir[cols_nir].values, cols_nir)


2.6 CORRELAÇÕES ESPECTRO-SC + PREDIÇÃO RÁPIDA
# README: CORRELAÇÃO ESPECTRAL
# ============================
# Correlação espectro vs atributos solo

def correlacao_espectral(df, cols_spec, target_col):
    corr = []
    for wl in cols_spec:
        r = df[wl].corr(df[target_col])
        corr.append(abs(r))
    
    plt.figure(figsize=(15,5))
    plt.plot(cols_spec, corr)
    plt.title(f'Correlação |{target_col}| vs Espectro')
    plt.xlabel('nm')
    plt.ylabel('|r|')
    plt.grid(True)
    plt.tight_layout()
    plt.show()
    
    # TOP 10 bandas
    top_bands = pd.DataFrame({'wl': cols_spec, 'corr': corr}).nlargest(10, 'corr')
    print(f"Top 10 bandas para {target_col}:")
    print(top_bands)

# CORRELAÇÕES IMPORTANTES AGRICULTURA
correlacao_espectral(df_nir, cols_nir, 'Argila')
correlacao_espectral(df_nir, cols_nir, 'SOC')
correlacao_espectral(df_nir, cols_nir, 'pH')


2.7 PCA + CLUSTERS
# README: PCA + KMEANS ZONAS MANEJO
# ================================
from sklearn.decomposition import PCA
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler

# PCA ESPECTROS
scaler = StandardScaler()
X_scaled = scaler.fit_transform(df_nir[cols_nir])

pca = PCA(n_components=3)
X_pca = pca.fit_transform(X_scaled)

print(f"Variância explicada: PC1={pca.explained_variance_ratio_[0]:.2%}, \
PC2={pca.explained_variance_ratio_[1]:.2%}")

# KMEANS
kmeans = KMeans(n_clusters=3, random_state=42)
clusters = kmeans.fit_predict(X_pca)

# PLOT
plt.figure(figsize=(15,5))

plt.subplot(1,3,1)
plt.scatter(X_pca[:,0], X_pca[:,1], c=clusters, cmap='viridis')
plt.title('PCA + Clusters')

plt.subplot(1,3,2)
df_nir['cluster'] = clusters
sns.boxplot(data=df_nir, x='cluster', y='SOC')
plt.title('SOC por cluster')

plt.subplot(1,3,3)
sns.boxplot(data=df_nir, x='cluster', y='Argila') 
plt.title('Argila por cluster')

plt.tight_layout()
plt.savefig('pca_clusters.png', dpi=300)
plt.show()


