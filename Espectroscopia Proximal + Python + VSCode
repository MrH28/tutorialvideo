# README: FEIÇÕES MINERAIS ESPECTRAIS
# ==================================
def identificar_minerais(df, cols_spec):
    """
    Picos típicos minerais solos brasileiros:
    """
    minerais = {
        'CaCO3': [2300],     # Carbonatos
        'Argila(Kaolinita)': [2200, 1410],
        'Óxidos Fe': [500, 900],
        'Matéria Orgânica': [1700],
        'Hidroxilas': [1400]
    }
    
    plt.figure(figsize=(15,8))
    media_spec = df[cols_spec].mean()
    
    for mineral, picos in minerais.items():
        for pico in picos:
            idx = np.argmin(np.abs(np.array(cols_spec).astype(float) - pico))
            plt.axvline(cols_spec[idx], color='red', alpha=0.7, linestyle='--')
            plt.text(cols_spec[idx], 0.1, f'{mineral}
({pico}nm)', 
                    rotation=90, fontsize=9)
    
    plt.plot(media_spec.index.astype(float), media_spec.values, linewidth=2)
    plt.title('Feições Minerais - Espectro Solo')
    plt.xlabel('nm')
    plt.ylabel('Reflectância')
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig('minerais_solo.png', dpi=300)
    plt.show()

identificar_minerais(df_nir, cols_nir)

