from sklearn.ensemble import RandomForestRegressor
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score, mean_squared_error

# PREPARAR DADOS
X = df_nir[cols_nir].values
y_argila = df_nir['Argila'].values

X_train, X_test, y_train, y_test = train_test_split(X, y_argila, test_size=0.3, random_state=42)

# RANDOM FOREST
rf = RandomForestRegressor(n_estimators=200, random_state=42)
rf.fit(X_train, y_train)
y_pred = rf.predict(X_test)

print(f"RF Argila: R²={r2_score(y_test, y_pred):.3f}")
print(f"RMSE={mean_squared_error(y_test, y_pred, squared=False):.2f}%")

# IMPORTÂNCIA VARIÁVEIS
importancia = pd.DataFrame({
    'banda': cols_nir,
    'importancia': rf.feature_importances_
}).nlargest(10, 'importancia')

print("Top 10 bandas preditivas Argila:")
print(importancia)


