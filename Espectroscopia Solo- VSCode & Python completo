2.4 EXTRAIR ESPECTROS VIS-NIR/MIR
# README: Separa espectros de metadados
# VIS-NIR: 400-2500nm | MIR: 4000-400cm-1

def extrair_espectros(df):
    # Colunas numéricas = wavenumbers
    spec_cols = [col for col in df.columns if col.replace('.','').isdigit()]
    wavenumbers = pd.to_numeric(spec_cols).sort_values().values
    
    # Espectros (amostras x wavenumbers)
    spectra = df[spec_cols].values.astype(np.float32)
    
    print(f"VIS-NIR/MIR: {spectra.shape}")
    return wavenumbers, spectra

wavenumbers, spectra = extrair_espectros(df)


