2.6 PRÉ-PROCESSAMENTO (SG + Derivadas)
# README: Remove ruído + destaca features minerais

from scipy.signal import savgol_filter

# 1. Suavização Savitzky-Golay
spectra_sg = savgol_filter(spectra, window_length=11, polyorder=3, axis=1)

# 2. 1ª e 2ª derivada
spectra_deriv1 = savgol_filter(spectra_sg, 11, 3, deriv=1, axis=1)
spectra_deriv2 = savgol_filter(spectra_sg, 11, 3, deriv=2, axis=1)

print("✅ SG + Deriv1 + Deriv2 OK")


2.7 CORRELAÇÃO ESPECTROS x ATRIBUTOS
# README: Identifica bandas preditivas argila/C-org

from scipy.stats import pearsonr

def correlacao_espectros(df, spectra_proc, alvo='clay_gkg'):
    correl = []
    for i, wn in enumerate(wavenumbers):
        r, _ = pearsonr(spectra_proc[:,i], df[alvo])
        correl.append(abs(r))
    
    plt.figure(figsize=(12,4))
    plt.plot(wavenumbers[::-1], correl)
    plt.title(f'Correlação |R| Espectro x {alvo}')
    plt.xlabel('Wavenumber (cm$^{-1}$)')
    plt.axhline(0.7, color='red', linestyle='--', label='R>0.7')
    plt.legend()
    plt.show()
    
    return correl

cor_clay = correlacao_espectros(df, spectra_deriv1)


2.8 IDENTIFICAR RUÍDO/FEIÇÕES
# README: Detecta ruído + minerais por absorção
def analisar_ruido_feicoes(spectra_sg):
    # Ruído: SNR < 10 (baixa relação sinal-ruído)
    snr = np.std(spectra_sg, axis=0) / np.mean(np.abs(np.diff(spectra_sg, axis=1)), axis=0)
    
    # Feições minerais típicas
    feicoes = {
        2900: 'C-H orgânicos', 1400: 'OH água', 
        1000: 'Si-O argila', 2200: 'Al-OH'
    }
    
    print("🔍 FEIÇÕES MINERAIS:")
    for wn, mineral in feicoes.items():
        idx = np.argmin(np.abs(wavenumbers - wn))
        print(f"{wn} cm-1: {mineral} (SNR: {snr[idx]:.1f})")


2.9 MODELAGEM PCA + CLUSTER
# README: Reduz 923 dims → 10 PCs + identifica estratos


from sklearn.decomposition import PCA
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler

# PCA
scaler = StandardScaler()
spectra_scaled = scaler.fit_transform(spectra_deriv1)

pca = PCA(n_components=0.95)
pc_result = pca.fit_transform(spectra_scaled)

# Clusters
kmeans = KMeans(n_clusters=4, random_state=42)
clusters = kmeans.fit_predict(pc_result)

plt.figure(figsize=(12,4))
plt.subplot(121)
plt.scatter(pc_result[:,0], pc_result[:,1], c=clusters)
plt.title('PCA + Clusters')

plt.subplot(122)
plt.bar(['PC1','PC2','PC3'], pca.explained_variance_ratio_[:3])
plt.title('Variância PCs')
plt.show()


2.10 RANDOM FOREST PREDIÇÃO
# README: Prediz clay/sand/C-org com PCs


from sklearn.ensemble import RandomForestRegressor
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score

def rf_predicao(df, pc_result, alvo):
    X_train, X_test, y_train, y_test = train_test_split(
        pc_result, df[alvo], test_size=0.3, random_state=42)
    
    rf = RandomForestRegressor(n_estimators=200, random_state=42)
    rf.fit(X_train, y_train)
    y_pred = rf.predict(X_test)
    
    r2 = r2_score(y_test, y_pred)
    print(f"{alvo}: R² = {r2:.3f}")
    return rf, r2

rf_clay, r2_clay = rf_predicao(df, pc_result, 'clay_gkg')
rf_sand, r2_sand = rf_predicao(df, pc_result, 'sand_gkg')


